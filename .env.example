# ─────────────────────────────────────────────────────────────────
# Guate Contable Pro — Local Development Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────

# Supabase / Lovable Cloud — these are PUBLIC (anon) keys.
# Safe to expose in client-side code.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-public-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ─────────────────────────────────────────────────────────────────
# NEVER add private keys here:
#   SUPABASE_SERVICE_ROLE_KEY  → lives only in Lovable Cloud Secrets
#   JWT secrets                → managed by Supabase internally
# ─────────────────────────────────────────────────────────────────
